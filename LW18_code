#include <iostream>
using namespace std;

void increment(int &arg) {
    arg++;
}

void increment(int &arg, int par) {
    arg += par;
}

int main(void) {
    int var = 0;
    
    for (int i = 0; i < 10; i++) {
        if (i % 2 != 0) {
            increment(var);
        }
        else {
            increment(var, i);
        }
    }

    cout << var << endl;
}
